{
  "name": "atlas-journey-watch",
  "version": "1.0.0",
  "private": true,
  "description": "Scheduled synthetic journeys across the public Atlas Systems estate.",
  "type": "module",
  "scripts": {
    "check": "node scripts/check.mjs",
    "test": "playwright test",
    "test:offline": "node scripts/run-offline-journeys.mjs",
    "test:release": "node scripts/run-release-journeys.mjs",
    "test:unit": "node --test tests/release-watch.test.mjs",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  },
  "engines": {
    "node": ">=22"
  }
}
